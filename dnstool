@echo off
chcp 65001 >nul
setlocal EnableExtensions EnableDelayedExpansion
title COMSS.ONE DNS CONTROLLER
color 0B

:: ===============================
:: CONFIG
:: ===============================
set "DNS1=76.76.2.22"
set "DNS2=76.76.10.22"
set "DOH=https://dns.comss.one/dns-query"
set "RULE_NAME=ComssDoH"
set "CFG=%~dp0selected_connection.txt"

call :RequireAdmin
if errorlevel 1 exit /b

call :LoadConnection
goto Main


:RequireAdmin
net session >nul 2>&1
if not errorlevel 1 exit /b 0

echo.
echo  Требуются права администратора...
powershell -NoProfile -Command "Start-Process -FilePath '%~f0' -Verb RunAs"
exit /b 1


:LoadConnection
set "adapter="

if exist "%CFG%" (
    set /p "adapter="<"%CFG%"
)

if defined adapter (
    powershell -NoProfile -Command "if (Get-NetAdapter -Name '%adapter%' -ErrorAction SilentlyContinue) { exit 0 } else { exit 1 }"
    if errorlevel 1 set "adapter="
)

if not defined adapter call :AutoPickConnection

if defined adapter (
    >"%CFG%" echo %adapter%
)

exit /b 0


:AutoPickConnection
set "adapter="

for /f "usebackq delims=" %%A in (`
    powershell -NoProfile -Command "Get-NetAdapter | Where-Object { $_.Status -eq 'Up' } | Sort-Object Name | Select-Object -First 1 -ExpandProperty Name"
`) do set "adapter=%%A"

if not defined adapter (
    for /f "usebackq delims=" %%A in (`
        powershell -NoProfile -Command "Get-NetAdapter | Where-Object { $_.Status -ne 'Disabled' } | Sort-Object Status,Name | Select-Object -First 1 -ExpandProperty Name"
    `) do set "adapter=%%A"
)

if defined adapter (
    >"%CFG%" echo %adapter%
)

exit /b 0


:GetStatus
set "adapter_type=Неизвестно"
set "adapter_ip=—"
set "adapter_profile=—"
set "adapter_dns=—"
set "dns_state=По умолчанию"

if not defined adapter exit /b 0

for /f "usebackq delims=" %%A in (`
    powershell -NoProfile -Command ^
    "$a = Get-NetAdapter -Name '%adapter%' -ErrorAction SilentlyContinue; " ^
    "if($a){ if($a.InterfaceDescription -match 'Wi-?Fi|Wireless|802\.11'){ 'Wi-Fi' } elseif($a.InterfaceDescription -match 'Ethernet|LAN'){ 'Ethernet' } else { 'Другой' } }"
`) do set "adapter_type=%%A"

for /f "usebackq delims=" %%A in (`
    powershell -NoProfile -Command ^
    "$p = Get-NetConnectionProfile -InterfaceIndex (Get-NetAdapter -Name '%adapter%' -ErrorAction SilentlyContinue).ifIndex -ErrorAction SilentlyContinue | Select-Object -First 1; if($p){ $p.Name }"
`) do set "adapter_profile=%%A"

for /f "usebackq delims=" %%A in (`
    powershell -NoProfile -Command ^
    "$a = Get-NetAdapter -Name '%adapter%' -ErrorAction SilentlyContinue; " ^
    "if($a){ $ip = Get-NetIPAddress -InterfaceIndex $a.ifIndex -AddressFamily IPv4 -ErrorAction SilentlyContinue | Where-Object { $_.IPAddress -notlike '169.254*' } | Select-Object -First 1 -ExpandProperty IPAddress; if($ip){ $ip } }"
`) do set "adapter_ip=%%A"

for /f "usebackq delims=" %%A in (`
    powershell -NoProfile -Command ^
    "$a = (Get-DnsClientServerAddress -InterfaceAlias '%adapter%' -AddressFamily IPv4 -ErrorAction SilentlyContinue).ServerAddresses; if((@($a) -contains '%DNS1%') -and (@($a) -contains '%DNS2%')) { 'DoH ВКЛ' } else { 'По умолчанию' }"
`) do set "dns_state=%%A"

for /f "usebackq delims=" %%A in (`
    powershell -NoProfile -Command ^
    "$a = (Get-DnsClientServerAddress -InterfaceAlias '%adapter%' -AddressFamily IPv4 -ErrorAction SilentlyContinue).ServerAddresses; if($a){ ($a -join ', ') }"
`) do set "adapter_dns=%%A"

exit /b 0


:Main
call :LoadConnection
call :GetStatus

cls
echo  =========================================
echo        COMSS.ONE DNS УТИЛИТА
echo  =========================================
echo.
echo  Подключение     : !adapter!
echo  Профиль         : !adapter_profile!
echo  Тип             : !adapter_type!
echo  IPv4            : !adapter_ip!
echo  DNS             : !adapter_dns!
echo  Статус          : !dns_state!
echo.
echo  [1] Переключить DNS
echo  [2] Информация
echo  [3] Выбрать подключение
echo  [4] Полный сброс
echo  [5] Выход
echo.

set /p "choice=Введите команду (1-5): "

if "%choice%"=="1" goto Toggle
if "%choice%"=="2" goto Info
if "%choice%"=="3" goto SelectConnection
if "%choice%"=="4" goto FullReset
if "%choice%"=="5" exit /b
echo.
echo  Неверная команда.
timeout /t 2 >nul
goto Main


:Toggle
call :GetStatus

if /i "!dns_state!"=="DoH ВКЛ" (
    goto TurnOff
) else (
    goto TurnOn
)


:TurnOn
echo.
echo  Применение Comss DNS...

powershell -NoProfile -Command ^
"$ErrorActionPreference='SilentlyContinue'; ^
 Get-DnsClientDohServerAddress -ServerAddress @('%DNS1%','%DNS2%') | Remove-DnsClientDohServerAddress -Confirm:$false -ErrorAction SilentlyContinue; ^
 Add-DnsClientDohServerAddress -ServerAddress '%DNS1%' -DohTemplate '%DOH%' -AllowFallbackToUdp $false -AutoUpgrade $true; ^
 Add-DnsClientDohServerAddress -ServerAddress '%DNS2%' -DohTemplate '%DOH%' -AllowFallbackToUdp $false -AutoUpgrade $true; ^
 Set-DnsClientServerAddress -InterfaceAlias '%adapter%' -ServerAddresses @('%DNS1%','%DNS2%'); ^
 Clear-DnsClientCache"

if errorlevel 1 (
    echo  [ОШИБКА] Не удалось включить DNS.
) else (
    echo  [OK] Comss DNS включён.
)

timeout /t 2 >nul
goto Main


:TurnOff
echo.
echo  Возврат на автоматический DNS...

powershell -NoProfile -Command ^
"$ErrorActionPreference='SilentlyContinue'; ^
 Set-DnsClientServerAddress -InterfaceAlias '%adapter%' -ResetServerAddresses; ^
 Get-DnsClientDohServerAddress -ServerAddress @('%DNS1%','%DNS2%') | Remove-DnsClientDohServerAddress -Confirm:$false -ErrorAction SilentlyContinue; ^
 Get-DnsClientNrptRule | Where-Object { $_.DisplayName -eq '%RULE_NAME%' } | Remove-DnsClientNrptRule -Force -ErrorAction SilentlyContinue; ^
 Clear-DnsClientCache"

if errorlevel 1 (
    echo  [ОШИБКА] Не удалось сбросить DNS.
) else (
    echo  [OK] DNS возвращён на автоматический.
)

timeout /t 2 >nul
goto Main


:SelectConnection
cls
echo  =========================================
echo        ВЫБОР ПОДКЛЮЧЕНИЯ
echo  =========================================
echo.

set "count=0"

for /f "usebackq tokens=1-5 delims=|" %%A in (`
    powershell -NoProfile -Command ^
    "Get-NetAdapter | Sort-Object Status,Name | ForEach-Object { ^
        $profile = (Get-NetConnectionProfile -InterfaceIndex $_.ifIndex -ErrorAction SilentlyContinue | Select-Object -First 1).Name; ^
        $ip = (Get-NetIPAddress -InterfaceIndex $_.ifIndex -AddressFamily IPv4 -ErrorAction SilentlyContinue | Where-Object { $_.IPAddress -notlike '169.254*' } | Select-Object -First 1 -ExpandProperty IPAddress); ^
        $type = if ($_.InterfaceDescription -match 'Wi-?Fi|Wireless|802\.11') { 'Wi-Fi' } elseif ($_.InterfaceDescription -match 'Ethernet|LAN') { 'Ethernet' } else { 'Другой' }; ^
        '{0}|{1}|{2}|{3}|{4}' -f $_.Name,$_.Status,$type,($profile -as [string]),($ip -as [string]) ^
    }"
`) do (
    set /a count+=1
    set "conn_name[!count!]=%%A"
    set "conn_status[!count!]=%%B"
    set "conn_type[!count!]=%%C"
    set "conn_profile[!count!]=%%D"
    set "conn_ip[!count!]=%%E"
    echo  [!count!] %%A  [%%B / %%C / Профиль: %%D / IP: %%E]
)

if !count! equ 0 (
    echo.
    echo  Подключения не найдены.
    pause
    goto Main
)

echo.
set /p "sel=Введите номер подключения: "
if not defined sel goto Main

call set "picked=%%conn_name[%sel%]%%"
if not defined picked (
    echo.
    echo  Неверный выбор.
    timeout /t 2 >nul
    goto SelectConnection
)

set "adapter=%picked%"
> "%CFG%" echo %adapter%

echo.
echo  Выбрано: %adapter%
timeout /t 1 >nul
goto Main


:FullReset
echo.
echo  Выполняется полный сброс...

powershell -NoProfile -Command ^
"$ErrorActionPreference='SilentlyContinue'; ^
 Set-DnsClientServerAddress -InterfaceAlias '%adapter%' -ResetServerAddresses; ^
 Get-DnsClientDohServerAddress -ServerAddress @('%DNS1%','%DNS2%') | Remove-DnsClientDohServerAddress -Confirm:$false -ErrorAction SilentlyContinue; ^
 Get-DnsClientNrptRule | Where-Object { $_.DisplayName -eq '%RULE_NAME%' } | Remove-DnsClientNrptRule -Force -ErrorAction SilentlyContinue; ^
 Clear-DnsClientCache"

del "%CFG%" >nul 2>&1
set "adapter="

if errorlevel 1 (
    echo  [ОШИБКА] Сброс выполнен не полностью.
) else (
    echo  [OK] Полный сброс завершён.
)

timeout /t 2 >nul
goto Main


:Info
cls
echo  =========================================
echo               ИНФОРМАЦИЯ
echo  =========================================
echo.
echo  DNS:
echo   %DNS1%
echo   %DNS2%
echo.
echo  DoH:
echo   %DOH%
echo.
echo  Что умеет утилита:
echo  - выбирает конкретное подключение;
echo  - запоминает выбор рядом с .bat;
echo  - показывает тип, профиль и IPv4;
echo  - включает и выключает DNS;
echo  - делает полный сброс на автоматический режим.
echo.
pause
goto Main
